es":false,"DataExportTag":"Q1","QuestionID":"QID1","QuestionType":"TE","Selector":"SL","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"How many respondents will be taking this survey?","Validation":{"Settings":{"ForceResponse":"OFF","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"SearchSource":{"AllowFreeResponse":"false"}}},{"SurveyID":"SV_6fZBO3lfcpXoODs","Element":"SQ","PrimaryAttribute":"QID10","SecondaryAttribute":"Welcome! Thank you for your interest in the Switchboard Survey. This is a relatively simple examp...","TertiaryAttribute":null,"Payload":{"ChoiceOrder":[],"Configuration":{"QuestionDescriptionOption":"UseText"},"DataExportTag":"Q11","DataVisibility":{"Hidden":false,"Private":false},"DefaultChoices":false,"GradingData":[],"Language":[],"NextAnswerId":1,"NextChoiceId":4,"QuestionDescription":"Welcome! Thank you for your interest in the Switchboard Survey. This is a relatively simple examp...","QuestionID":"QID10","QuestionText":"Welcome! Thank you for your interest in the Switchboard Survey.<br><br>This is a relatively simple example to help you get started.<br><br>More complex surveys can be created using Branch Logic and Loop &amp; Merge.<br><br>https:\/\/www.qualtrics.com\/support\/survey-platform\/survey-module\/survey-flow\/standard-elements\/branch-logic\/<br>https:\/\/www.qualtrics.com\/support\/survey-platform\/survey-module\/block-options\/loop-and-merge\/<br><br><br>More details on the Switchboard Survey can be found here: https:\/\/github.com\/EliseAtkinson\/Qualtrics-Switchboard-Survey<br><br>","QuestionText_Unsafe":"Welcome! Thank you for your interest in the Mental Health Screeners for Autistic Youth study.<br><br>This is the webpage for a caregiver of an autistic youth (12 to 19 year-old) to enroll in the study. <br><br>The webpage will walk you through three different forms to complete. <br><br>Completing all four forms should take approximately 10 minutes.<br><br>","QuestionType":"DB","Selector":"TB","Validation":{"Settings":{"Type":"None"}},"QuestionJS":"Qualtrics.SurveyEngine.addOnload(function() {\n \/\/ Generates a random number 5 digits long\n    var randomNumber = Math.floor(10000 + Math.random() * 90000);\n \/\/ Sets the value of the random number to the UniqueID embedded data field\n    Qualtrics.SurveyEngine.setEmbeddedData('UniqueID', randomNumber);\n});"}},{"SurveyID":"SV_6fZBO3lfcpXoODs","Element":"SQ","PrimaryAttribute":"QID11","SecondaryAttribute":"The Switchboard Survey is designed to split data into multiple Endpoints while having respondents...","TertiaryAttribute":null,"Payload":{"ChoiceOrder":[],"Configuration":{"QuestionDescriptionOption":"UseText"},"DataExportTag":"Q12","DataVisibility":{"Hidden":false,"Private":false},"DefaultChoices":false,"GradingData":[],"Language":[],"NextAnswerId":1,"NextChoiceId":4,"QuestionDescription":"The Switchboard Survey is designed to split data into multiple Endpoints while having respondents...","QuestionID":"QID11","QuestionText":"The Switchboard Survey is designed to split data into multiple Endpoints while having respondents only answer one survey.<br><br>Below are two example Endpoints: a&nbsp;<strong>consent form <\/strong>and a<strong> survey.<\/strong><br><br>This means the answers from the consent will be only found within the consent form Endpoint. This is useful for splitting identifying information and anonymized data. A code created in the first question of the Switchboard creates a UniqueID that can be used to link the data.<br>","QuestionText_Unsafe":"These are the three forms we'll ask you to complete:<br>\n<br>\n1. The <strong>consent form<\/strong>, which describes the research study further.<br>\n<br>\n2. The <strong>contact information form<\/strong>, which tells us the best way to contact you to schedule you for a study.<br>\n<br>\n3. The <strong>survey<\/strong>, which is a 5 minute survey to let us know more about you.<br>\n<br>Clicking on the arrow below will start the first form, which is the consent form.","QuestionType":"DB","Selector":"TB","Validation":{"Settings":{"Type":"None"}}}},{"SurveyID":"SV_6fZBO3lfcpXoODs","Element":"SQ","PrimaryAttribute":"QID2","SecondaryAttribute":"This is the consent for respondent\u00a0${lm:\/\/Field\/1}","TertiaryAttribute":null,"Payload":{"QuestionText":"<div role=\"navigation\" id=\"Buttons\"> \n  <p style=\"text-align: left;\">\n\n   This is the consent for respondent&nbsp;${lm:\/\/Field\/1}<br>\n\n   <iframe src=\"https:\/\/msu.co1.qualtrics.com\/jfe\/form\/SV_3U9JiW8Ro4Xy8Yu?UniqueID=${e:\/\/Field\/UniqueID}&amp;Loop=${lm:\/\/Field\/1}\" id=\"Iframe\">\n   <\/iframe>\n\t\t<\/p>\n\t<\/div>\n<\/body>\n\n<\/html>\n","DefaultChoices":false,"DataExportTag":"Q2","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"This is the consent for respondent\u00a0${lm:\/\/Field\/1}","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID2"}},{"SurveyID":"SV_6fZBO3lfcpXoODs","Element":"SQ","PrimaryAttribute":"QID3","SecondaryAttribute":"This is the survey example. Only edit in HTML view. Replace only the portion of the code PASTE LI...","TertiaryAttribute":null,"Payload":{"QuestionText":"<!DOCTYPE HTML>\n<head> \n\n\t<meta charset=\"UTF-8\">\n\t<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n\t<style>\n\t\t#Iframe { width: 100%; height: 500px; border: 1px solid #ccc; }\n\t<\/style>\n    <script>\n        \/\/ Event listener for messages from the iframe\n        window.addEventListener('message', function(event) {\n            if (event.data === 'surveyCompleted') {\n                \/\/ Show the Next button\n                $('NextButton').show();\n            }\n        });\n    <\/script>\n      <\/head>\n\n<body>\n\n\t<d